# Ferrum local demo – copy to .env and adjust as needed.
# Usage: cp deploy/.env.example .env && docker compose -f deploy/docker-compose.yml up -d

# --- PostgreSQL ---
POSTGRES_USER=ferrum
POSTGRES_PASSWORD=ferrum
POSTGRES_DB=ferrum

# --- MinIO (S3-compatible) ---
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_BUCKET=ferrum

# --- Keycloak (OIDC) ---
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin
KEYCLOAK_REALM=ferrum
# JWKS URL for Ferrum gateway (after Keycloak is up). For local: use host port if gateway is behind nginx.
KEYCLOAK_JWKS_URL=http://localhost:8081/realms/ferrum/protocol/openid-connect/certs

# --- Published ports ---
GATEWAY_PORT=8080
UI_PORT=8082

# --- Optional: Ferrum config overrides (env vars take precedence over config.toml) ---
# FERRUM_BIND=0.0.0.0:8080
# FERRUM_DATABASE__URL=postgres://ferrum:ferrum@postgres:5432/ferrum
# FERRUM_DATABASE__RUN_MIGRATIONS=true
# FERRUM_STORAGE__BACKEND=s3
# FERRUM_STORAGE__S3_ENDPOINT=http://minio:9000
# FERRUM_STORAGE__S3_REGION=us-east-1
# FERRUM_STORAGE__S3_BUCKET=ferrum
# FERRUM_STORAGE__S3_ACCESS_KEY_ID=minioadmin
# FERRUM_STORAGE__S3_SECRET_ACCESS_KEY=minioadmin
# FERRUM_AUTH__JWKS_URL=http://keycloak:8080/realms/ferrum/protocol/openid-connect/certs
# FERRUM_AUTH__REQUIRE_AUTH=false

# --- Optional: WES → TES (nested Docker / GA4GH-style demos; all off by default) ---
# See docs/TES-DOCKER-BACKEND.md
# FERRUM_WES_TES_WORK_HOST_PREFIX=/data/wes-runs
# FERRUM_WES_TES_CONTAINER_WORKDIR=/data/wes-runs
# FERRUM_WES_TES_WDL_BASH_LAUNCH=1
# FERRUM_WES_TES_NEXTFLOW_FILE_LAUNCH=1

# --- Optional: TES Docker executor (only when gateway built with --features tes-docker) ---
# FERRUM_TES_DOCKER_MOUNT_SOCKET=1
# FERRUM_TES_DOCKER_CLI_HOST_PATH=/usr/bin/docker
# FERRUM_TES_DOCKER_NETWORK_MODE=host
# FERRUM_TES_DOCKER_EXTRA_HOSTS=host.docker.internal:host-gateway
# FERRUM_TES_DOCKER_PLATFORM=linux/amd64
