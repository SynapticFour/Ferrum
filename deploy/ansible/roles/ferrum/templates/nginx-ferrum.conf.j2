# Ferrum reverse proxy with TLS (Ansible-managed)
upstream ferrum_gateway {
    server 127.0.0.1:8080;
}

server {
    listen 80;
    server_name {{ ferrum_nginx_server_name | default('ferrum.example.com') }};
    return 301 https://$server_name$request_uri;
}

server {
    listen 443 ssl http2;
    server_name {{ ferrum_nginx_server_name | default('ferrum.example.com') }};

    ssl_certificate     {{ ferrum_nginx_ssl_cert | default('/etc/ssl/certs/ferrum.pem') }};
    ssl_certificate_key {{ ferrum_nginx_ssl_key | default('/etc/ssl/private/ferrum-key.pem') }};
    ssl_protocols       TLSv1.2 TLSv1.3;
    ssl_ciphers         HIGH:!aNULL:!MD5;

    client_max_body_size 100M;

    location / {
        proxy_pass http://ferrum_gateway;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }
}
